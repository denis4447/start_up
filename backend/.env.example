# AI Tunnel API Key (OpenAI-compatible) - KEEP THIS SECRET
OPENAI_API_KEY=sk-aitunnel-your-key-here

# AI Tunnel Base URL
OPENAI_BASE_URL=https://api.aitunnel.ru/v1/

# JWT Secret - generate a strong random string
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server Configuration
PORT=3001
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Web Push (VAPID) — generate with: node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys()))"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
